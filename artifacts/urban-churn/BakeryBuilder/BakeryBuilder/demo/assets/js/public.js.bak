(function($) {
    'use strict';
    
    let currentOrderType = '';
    let basePrice = 0;
    let topperPrice = 0;
    let colorPrice = 0;
    let currentStep = 1;
    let cupcakeQuantity = 1;
    
    // Performance optimization: Debounce function for input events
    function debounce(func, wait) {
        let timeout;
        return function executedFunction(...args) {
            const later = () => {
                clearTimeout(timeout);
                func(...args);
            };
            clearTimeout(timeout);
            timeout = setTimeout(later, wait);
        };
    }
    
    // Performance optimization: Request Animation Frame throttle
    function throttleRAF(func) {
        let running = false;
        return function(...args) {
            if (running) return;
            running = true;
            requestAnimationFrame(() => {
                func.apply(this, args);
                running = false;
            });
        };
    }
    
    $(document).ready(function() {
        // Add passive event listeners for better scroll performance
        if ('passive' in $.event.special) {
            $.event.special.touchstart = { setup: function() { this.addEventListener('touchstart', $.noop, { passive: true }); } };
            $.event.special.touchmove = { setup: function() { this.addEventListener('touchmove', $.noop, { passive: true }); } };
        }
        
        initFormHandlers();
        initDatePicker();
        initAccordion();
        initCharacterCounters();
        initQuantitySelector();
        initMobileNavigation();
    });
    
    function initCharacterCounters() {
        // Debounced preview update for better performance
        const debouncedPreviewUpdate = debounce(updateVisualPreview, 150);
        
        // Topper text counter
        $('#topper_text').on('input', function() {
            const length = $(this).val().length;
            const max = $(this).attr('maxlength');
            $('#topper_char_count').text(length);
            
            const counter = $(this).siblings('.ucbo-char-counter');
            counter.removeClass('warning limit');
            
            if (length >= max * 0.8 && length < max) {
                counter.addClass('warning');
            } else if (length >= max) {
                counter.addClass('limit');
            }
            
            // Update preview when topper text changes (debounced)
            debouncedPreviewUpdate();
        });
        
        // Color request counter
        $('#color_request').on('input', function() {
            const length = $(this).val().length;
            const max = $(this).attr('maxlength');
            $('#color_char_count').text(length);
            
            const counter = $(this).siblings('.ucbo-char-counter');
            counter.removeClass('warning limit');
            
            if (length >= max * 0.8 && length < max) {
                counter.addClass('warning');
            } else if (length >= max) {
                counter.addClass('limit');
            }
        });
    }
    
    function initQuantitySelector() {
        $('.ucbo-qty-btn').on('click', function() {
            const btn = $(this);
            const input = $('#cupcake_quantity');
            let value = parseInt(input.val());
            const min = parseInt(input.attr('min'));
            const max = parseInt(input.attr('max'));
            
            if (btn.hasClass('ucbo-qty-minus')) {
                value = Math.max(min, value - 1);
                btn.addClass('ucbo-btn-pressed');
            } else {
                value = Math.min(max, value + 1);
                btn.addClass('ucbo-btn-pressed');
            }
            
            setTimeout(() => btn.removeClass('ucbo-btn-pressed'), 200);
            
            input.val(value);
            cupcakeQuantity = value;
            updatePriceDisplay();
            updateVisualPreview();
        });
    }
    
    function initMobileNavigation() {
        // Create mobile navigation if it doesn't exist
        if ($('.ucbo-mobile-step-nav').length === 0) {
            const mobileNav = $('<div class="ucbo-mobile-step-nav">' +
                '<button type="button" class="ucbo-mobile-prev" disabled>← Previous</button>' +
                '<button type="button" class="ucbo-mobile-next primary">Next →</button>' +
            '</div>');
            
            $('.ucbo-form-container').append(mobileNav);
        }
        
        // Mobile navigation handlers
        $('.ucbo-mobile-prev').on('click', function() {
            if (currentStep > 1) {
                navigateToStep(currentStep - 1);
            }
        });
        
        $('.ucbo-mobile-next').on('click', function() {
            if (currentStep < 4) {
                navigateToStep(currentStep + 1);
            }
        });
        
        updateMobileNav();
    }
    
    function navigateToStep(stepNum) {
        const $currentHeader = $('.ucbo-accordion-step[data-step="' + currentStep + '"] .ucbo-accordion-header');
        const $nextHeader = $('.ucbo-accordion-step[data-step="' + stepNum + '"] .ucbo-accordion-header');
        
        // Close current
        $currentHeader.removeClass('active');
        $currentHeader.siblings('.ucbo-accordion-content').removeClass('active');
        
        // Open next
        $nextHeader.addClass('active');
        $nextHeader.siblings('.ucbo-accordion-content').addClass('active');
        
        currentStep = stepNum;
        updateMobileNav();
        
        // Scroll to step
        $('html, body').animate({
            scrollTop: $nextHeader.offset().top - 20
        }, 300);
    }
    
    function updateMobileNav() {
        $('.ucbo-mobile-prev').prop('disabled', currentStep === 1);
        $('.ucbo-mobile-next').prop('disabled', currentStep === 4);
        
        if (currentStep === 4) {
            $('.ucbo-mobile-next').text('Complete →');
        } else {
            $('.ucbo-mobile-next').text('Next →');
        }
    }
    
    function initAccordion() {
        // Accordion click handlers
        $('.ucbo-accordion-header').on('click', function() {
            const $header = $(this);
            const $step = $header.parent('.ucbo-accordion-step');
            const stepNumber = parseInt($step.data('step'));
            
            // Don't allow clicking on disabled steps
            if ($header.hasClass('disabled')) {
                return;
            }
            
            // Toggle the clicked accordion
            if ($header.hasClass('active')) {
                // Collapse if already active
                $header.removeClass('active');
                $step.find('.ucbo-accordion-content').removeClass('active');
            } else {
                // Expand the clicked step
                $header.addClass('active');
                $step.find('.ucbo-accordion-content').addClass('active');
                
                // If opening Step 3, check if order type is selected
                if (stepNumber === 3) {
                    checkStep3OrderType();
                }
            }
        });
        
        // Validate each step when fields change
        validateStep1OnChange();
        validateStep2OnChange();
        validateStep3OnChange();
    }
    
    function checkStep3OrderType() {
        const orderType = $('input[name="order_type"]:checked').val();
        if (!orderType) {
            $('#no-order-type-message').show();
            $('.ucbo-order-options').hide();
            $('#addons-section').hide();
        }
    }
    
    function validateStep1OnChange() {
        const step1Fields = ['#customer_name', '#customer_phone', '#customer_email', '#pickup_date', '#pickup_time'];
        
        step1Fields.forEach(function(field) {
            $(field).on('blur change', function() {
                checkStep1Completion();
            });
        });
    }
    
    function checkStep1Completion() {
        const isComplete = 
            $('#customer_name').val().trim() !== '' &&
            $('#customer_phone').val().trim() !== '' &&
            $('#customer_email').val().trim() !== '' &&
            $('#pickup_date').val() !== '' &&
            $('#pickup_time').val() !== '';
        
        const $step1 = $('.ucbo-accordion-step[data-step="1"]');
        const $step1Header = $step1.find('.ucbo-accordion-header');
        const $step2Header = $('.ucbo-accordion-step[data-step="2"] .ucbo-accordion-header');
        
        if (isComplete) {
            $step1Header.addClass('completed');
            $step1.addClass('completed');
            $step2Header.removeClass('disabled');
            
            // Auto-open step 2 ONLY if step 1 is fully complete
            setTimeout(function() {
                if (!$step2Header.hasClass('active')) {
                    $step1Header.removeClass('active');
                    $step1.find('.ucbo-accordion-content').removeClass('active');
                    $step2Header.addClass('active');
                    $step2Header.siblings('.ucbo-accordion-content').addClass('active');
                }
            }, 300);
        } else {
            $step1Header.removeClass('completed');
            $step1.removeClass('completed');
            $step2Header.addClass('disabled');
        }
    }
    
    function validateStep2OnChange() {
        $('input[name="order_type"]').on('change', function() {
            checkStep2Completion();
        });
    }
    
    function checkStep2Completion() {
        const isComplete = $('input[name="order_type"]:checked').length > 0;
        
        const $step2 = $('.ucbo-accordion-step[data-step="2"]');
        const $step2Header = $step2.find('.ucbo-accordion-header');
        const $step3Header = $('.ucbo-accordion-step[data-step="3"] .ucbo-accordion-header');
        
        if (isComplete) {
            $step2Header.addClass('completed');
            $step2.addClass('completed');
            $step3Header.removeClass('disabled');
            
            // Auto-open step 3 if step 2 is complete
            setTimeout(function() {
                if (!$step3Header.hasClass('active')) {
                    $step2Header.removeClass('active');
                    $step2.find('.ucbo-accordion-content').removeClass('active');
                    $step3Header.addClass('active');
                    $step3Header.siblings('.ucbo-accordion-content').addClass('active');
                }
            }, 300);
        } else {
            $step2Header.removeClass('completed');
            $step2.removeClass('completed');
            $step3Header.addClass('disabled');
        }
    }
    
    function validateStep3OnChange() {
        $('input[name="pre_stacked_flavor"], input[name="ice_cream_flavor"], input[name="cupcake_flavor"], input[name="cake_flavor"], input[name="frosting_type"], input[name="filling"]').on('change', function() {
            checkStep3Completion();
            updateVisualPreview();
        });
    }
    
    function checkStep3Completion() {
        let isComplete = false;
        
        const orderType = $('input[name="order_type"]:checked').val();
        
        if (orderType === 'Pre-Stacked Ice Cream Cake') {
            isComplete = $('input[name="pre_stacked_flavor"]:checked').length > 0;
        } else if (orderType === 'Custom Ice Cream Cake') {
            isComplete = 
                $('input[name="cake_flavor"]:checked').length > 0 &&
                $('input[name="ice_cream_flavor"]:checked').length > 0 &&
                $('input[name="frosting_type"]:checked').length > 0;
        } else if (orderType === 'Cupcakes by the Dozen') {
            isComplete = $('input[name="cupcake_flavor"]:checked').length > 0;
        }
        
        const $step3 = $('.ucbo-accordion-step[data-step="3"]');
        const $step3Header = $step3.find('.ucbo-accordion-header');
        const $step4Header = $('.ucbo-accordion-step[data-step="4"] .ucbo-accordion-header');
        
        if (isComplete) {
            $step3Header.addClass('completed');
            $step3.addClass('completed');
            $step4Header.removeClass('disabled');
            
            // Confetti micro-interaction
            createConfetti($step3Header);
            
            // Auto-open step 4 ONLY if step 3 is fully complete
            setTimeout(function() {
                if (!$step4Header.hasClass('active')) {
                    $step3Header.removeClass('active');
                    $step3.find('.ucbo-accordion-content').removeClass('active');
                    $step4Header.addClass('active');
                    $step4Header.siblings('.ucbo-accordion-content').addClass('active');
                }
            }, 500);
        } else {
            $step3Header.removeClass('completed');
            $step3.removeClass('completed');
            $step4Header.addClass('disabled');
        }
    }
    
    function initFormHandlers() {
        $('input[name="order_type"]').on('change', handleOrderTypeChange);
        
        // Flavor card handlers
        $('input[name="pre_stacked_flavor"], input[name="cake_flavor"], input[name="ice_cream_flavor"], input[name="cupcake_flavor"], input[name="filling"]').on('change', function() {
            updateVisualPreview();
            checkStep3Completion();
            
            // Micro-interaction: pulse effect
            $(this).siblings('.ucbo-flavor-card-content').addClass('ucbo-pulse');
            setTimeout(() => {
                $(this).siblings('.ucbo-flavor-card-content').removeClass('ucbo-pulse');
            }, 400);
        });
        
        $('#topper_checkbox').on('change', handleTopperChange);
        $('#color_accents_checkbox').on('change', handleColorAccentsChange);
        
        $('input[name="frosting_type"]').on('change', updateVisualPreview);
        
        // Form submission - only attach if not in demo mode
        if (typeof ucboData !== 'undefined' && ucboData.ajaxUrl && ucboData.ajaxUrl !== 'demo-handler.php') {
            $('#ucbo-order-form').on('submit', handleFormSubmit);
        }
    }
    
    function initDatePicker() {
        const dateInput = $('#pickup_date');
        const leadTimeHours = ucboData.leadTimeHours || 96;
        const minDate = new Date();
        minDate.setHours(minDate.getHours() + leadTimeHours);
        
        const minDateString = minDate.toISOString().split('T')[0];
        dateInput.attr('min', minDateString);
    }
    
    function handleOrderTypeChange() {
        const selectedType = $('input[name="order_type"]:checked').val();
        currentOrderType = selectedType;
        
        $('.ucbo-order-options').hide();
        $('#addons-section').hide();
        $('#no-order-type-message').hide();
        
        if (selectedType === 'Pre-Stacked Ice Cream Cake') {
            basePrice = 65;
            $('#pre-stacked-options').slideDown(400);
            $('#addons-section').slideDown(400);
            
            // Restore addon prices based on checkbox states
            topperPrice = $('#topper_checkbox').is(':checked') ? 8.50 : 0;
            colorPrice = $('#color_accents_checkbox').is(':checked') ? 10 : 0;
        } else if (selectedType === 'Custom Ice Cream Cake') {
            basePrice = 75;
            $('#custom-cake-options').slideDown(400);
            $('#addons-section').slideDown(400);
            
            // Restore addon prices based on checkbox states
            topperPrice = $('#topper_checkbox').is(':checked') ? 8.50 : 0;
            colorPrice = $('#color_accents_checkbox').is(':checked') ? 10 : 0;
        } else if (selectedType === 'Cupcakes by the Dozen') {
            basePrice = 36;
            $('#cupcakes-options').slideDown(400);
            
            // Cupcakes don't have topper or color options - reset prices
            topperPrice = 0;
            colorPrice = 0;
        }
        
        updatePriceDisplay();
        updateVisualPreview();
    }
    
    function handleTopperChange() {
        const isChecked = $(this).is(':checked');
        topperPrice = isChecked ? 8.50 : 0;
        
        if (isChecked) {
            $('#topper_text_container').slideDown(300);
            $('#topper_text').attr('required', true);
        } else {
            $('#topper_text_container').slideUp(300);
            $('#topper_text').attr('required', false);
            $('#topper_text').val('');
        }
        
        updatePriceDisplay();
        updateVisualPreview();
    }
    
    function handleColorAccentsChange() {
        const isChecked = $(this).is(':checked');
        colorPrice = isChecked ? 10 : 0;
        
        if (isChecked) {
            $('#color_request_container').slideDown(300);
            $('#color_request').attr('required', true);
        } else {
            $('#color_request_container').slideUp(300);
            $('#color_request').attr('required', false);
            $('#color_request').val('');
        }
        
        updatePriceDisplay();
        updateVisualPreview(); // Update preview when color accents change
    }
    
    function updatePriceDisplay() {
        let itemPrice = basePrice;
        
        // For cupcakes, multiply by quantity
        if (currentOrderType === 'Cupcakes by the Dozen') {
            itemPrice = basePrice * cupcakeQuantity;
            $('#ucbo-quantity-price').show();
            $('#ucbo-quantity-display').text(cupcakeQuantity + 'x $' + basePrice.toFixed(2));
        } else {
            $('#ucbo-quantity-price').hide();
        }
        
        const totalPrice = itemPrice + topperPrice + colorPrice;
        
        $('#ucbo-base-price').text('$' + basePrice.toFixed(2));
        $('#ucbo-total-price').text('$' + totalPrice.toFixed(2));
        
        // Animate price change
        $('#ucbo-total-price').addClass('ucbo-price-pulse');
        setTimeout(() => {
            $('#ucbo-total-price').removeClass('ucbo-price-pulse');
        }, 500);
        
        if (topperPrice > 0) {
            $('#ucbo-topper-price').slideDown(200);
        } else {
            $('#ucbo-topper-price').slideUp(200);
        }
        
        if (colorPrice > 0) {
            $('#ucbo-color-price').slideDown(200);
        } else {
            $('#ucbo-color-price').slideUp(200);
        }
    }
    
    function updateVisualPreview() {
        const preview = $('#ucbo-cake-preview');
        
        if (!currentOrderType) {
            return;
        }
        
        if (currentOrderType === 'Cupcakes by the Dozen') {
            renderCupcakePreview(preview);
        } else {
            renderCakePreview(preview);
        }
    }
    
    function renderCakePreview(preview) {
        const hasTopper = $('#topper_checkbox').is(':checked');
        const topperText = $('#topper_text').val() || '';
        const hasColorAccents = $('#color_accents_checkbox').is(':checked');
        
        // Get flavor selections
        let cakeFlavor = '';
        let iceCreamFlavor = '';
        let frostingType = '';
        let filling = '';
        
        if (currentOrderType === 'Pre-Stacked Ice Cream Cake') {
            iceCreamFlavor = $('input[name="pre_stacked_flavor"]:checked').val() || '';
            // For pre-stacked, both layers use the same ice cream flavor
            cakeFlavor = iceCreamFlavor;
            frostingType = 'whipped'; // Pre-stacked defaults to whipped
        } else if (currentOrderType === 'Custom Ice Cream Cake') {
            cakeFlavor = $('input[name="cake_flavor"]:checked').val() || '';
            iceCreamFlavor = $('input[name="ice_cream_flavor"]:checked').val() || '';
            frostingType = $('input[name="frosting_type"]:checked').val() || '';
            filling = $('input[name="filling"]:checked').val() || '';
        }
        
        // Normalize flavor names for CSS classes
        const cakeFlavorClass = normalizeFlavor(cakeFlavor);
        const iceCreamFlavorClass = normalizeFlavor(iceCreamFlavor);
        const frostingClass = normalizeFlavor(frostingType);
        const fillingClass = normalizeFlavor(filling);
        
        let html = '<div style="width: 100%; max-width: 250px; margin: 0 auto; position: relative;">';
        
        // Frosting layer (top) - needs to be first for topper to be on top
        let frostingClasses = 'ucbo-cake-layer ucbo-cake-frosting';
        let frostingLabel = 'Frosting';
        if (frostingClass === 'buttercream') {
            frostingClasses += ' buttercream';
            frostingLabel = 'Buttercream Frosting';
        } else if (frostingClass === 'whipped-topping') {
            frostingClasses += ' whipped';
            frostingLabel = 'Whipped Topping';
        }
        if (hasColorAccents) {
            frostingClasses += ' with-sprinkles';
        }
        html += '<div class="' + frostingClasses + '" data-flavor="' + frostingLabel + '" style="animation-delay: 0.6s; position: relative;">';
        
        // Topper with handwriting - inside frosting layer
        if (hasTopper && topperText.trim()) {
            html += '<div class="ucbo-cake-topper">' + escapeHtml(topperText) + '</div>';
        }
        
        html += '</div>';
        
        // Ice cream layer (top layer)
        let iceCreamClasses = 'ucbo-cake-layer ucbo-cake-middle';
        let iceCreamLabel = iceCreamFlavor || 'Ice Cream Layer';
        if (iceCreamFlavorClass) {
            iceCreamClasses += ' ' + iceCreamFlavorClass;
        }
        html += '<div class="' + iceCreamClasses + '" data-flavor="' + iceCreamLabel + '" style="animation-delay: 0.4s;"></div>';
        
        // Filling layer (if selected and custom cake)
        if (filling && currentOrderType === 'Custom Ice Cream Cake') {
            let fillingLayerClass = 'ucbo-cake-filling';
            if (fillingClass) {
                fillingLayerClass += ' ' + fillingClass;
            }
            html += '<div class="' + fillingLayerClass + '" data-flavor="' + filling + '" style="animation-delay: 0.2s;"></div>';
        }
        
        // Cake/Ice Cream layer (base)
        let cakeClasses = 'ucbo-cake-layer ucbo-cake-base';
        let cakeLabel = '';
        
        if (currentOrderType === 'Pre-Stacked Ice Cream Cake') {
            // For pre-stacked, base is also ice cream (same flavor)
            cakeLabel = iceCreamFlavor || 'Ice Cream Layer';
            if (iceCreamFlavorClass) {
                cakeClasses += ' ucbo-cake-middle ' + iceCreamFlavorClass;
            }
        } else {
            // For custom, base is cake
            cakeLabel = cakeFlavor || 'Cake Layer';
            if (cakeFlavorClass) {
                cakeClasses += ' ' + cakeFlavorClass;
            }
        }
        
        html += '<div class="' + cakeClasses + '" data-flavor="' + cakeLabel + '" style="animation-delay: 0s;"></div>';
        
        html += '</div>';
        
        preview.html(html);
    }
    
    function renderCupcakePreview(preview) {
        const cupcakeFlavor = $('input[name="cupcake_flavor"]:checked').val() || '';
        const flavorClass = normalizeFlavor(cupcakeFlavor);
        const quantity = cupcakeQuantity * 12; // Total cupcakes
        
        let html = '<div class="ucbo-cupcake-grid">';
        
        for (let i = 0; i < 12; i++) {
            html += '<div class="ucbo-cupcake ' + flavorClass + '" style="--index: ' + i + ';" data-flavor="' + (cupcakeFlavor || 'Cupcake') + '"></div>';
        }
        
        html += '</div>';
        
        if (cupcakeQuantity > 1) {
            html += '<p style="text-align: center; margin-top: 15px; font-weight: 600; color: var(--bakery-pink);">× ' + cupcakeQuantity + ' dozen = ' + quantity + ' total cupcakes</p>';
        }
        
        preview.html(html);
    }
    
    function normalizeFlavor(flavor) {
        if (!flavor) return '';
        
        // Convert flavor names to CSS class names
        const flavorMap = {
            'vanilla': 'vanilla',
            'chocolate': 'chocolate',
            'red velvet': 'red-velvet',
            'funfetti': 'funfetti',
            'cookies \'n cream': 'cookies-cream',
            'cookies n cream': 'cookies-cream',
            'peanut butter cup': 'peanut-butter',
            'peanut butter': 'peanut-butter',
            'strawberries & cream': 'strawberry',
            'strawberries \'n cream': 'strawberry',
            'strawberries n cream': 'strawberry',
            'strawberry': 'strawberry',
            'mint chocolate chip': 'mint-chip',
            'double chocolate': 'chocolate',
            'pumpkin (seasonal)': 'pumpkin',
            'pumpkin': 'pumpkin',
            'buttercream': 'buttercream',
            'whipped topping': 'whipped-topping',
            'raspberry jam': 'raspberry',
            'chocolate ganache': 'chocolate-ganache',
            'cherry filling': 'cherry',
            'salted caramel': 'caramel'
        };
        
        const normalized = flavor.toLowerCase().trim();
        return flavorMap[normalized] || '';
    }
    
    function escapeHtml(text) {
        const map = {
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#039;'
        };
        return text.replace(/[&<>"']/g, function(m) { return map[m]; });
    }
    
    function handleFormSubmit(e) {
        e.preventDefault();
        
        const submitBtn = $('.ucbo-submit-btn');
        submitBtn.prop('disabled', true);
        $('.ucbo-btn-text').hide();
        $('.ucbo-btn-loading').show();
        
        const formData = {
            action: 'ucbo_submit_order',
            nonce: ucboData.nonce,
            customer_name: $('#customer_name').val(),
            customer_phone: $('#customer_phone').val(),
            customer_email: $('#customer_email').val(),
            pickup_date: $('#pickup_date').val(),
            pickup_time: $('#pickup_time').val(),
            referral: $('#referral').val(),
            order_type: $('input[name="order_type"]:checked').val(),
            topper: $('#topper_checkbox').is(':checked') ? 'yes' : 'no',
            topper_text: $('#topper_text').val(),
            color_accents: $('#color_accents_checkbox').is(':checked') ? 'yes' : 'no',
            color_request: $('#color_request').val(),
            special_requests: $('#special_requests').val()
        };
        
        if (formData.order_type === 'Pre-Stacked Ice Cream Cake') {
            formData.flavor = $('input[name="pre_stacked_flavor"]:checked').val();
        } else if (formData.order_type === 'Custom Ice Cream Cake') {
            formData.cake_flavor = $('input[name="cake_flavor"]:checked').val();
            formData.ice_cream_flavor = $('input[name="ice_cream_flavor"]:checked').val();
            formData.frosting_type = $('input[name="frosting_type"]:checked').val();
            formData.filling = $('input[name="filling"]:checked').val();
        } else if (formData.order_type === 'Cupcakes by the Dozen') {
            formData.flavor = $('input[name="cupcake_flavor"]:checked').val();
            formData.quantity = cupcakeQuantity;
        }
        
        $.ajax({
            url: ucboData.ajaxUrl,
            type: 'POST',
            data: formData,
            success: function(response) {
                if (response.success) {
                    $('#ucbo-order-form').fadeOut(400, function() {
                        $('#ucbo-success-message').fadeIn(400);
                    });
                    
                    $('html, body').animate({
                        scrollTop: $('.ucbo-form-container').offset().top - 20
                    }, 500);
                } else {
                    alert(response.data.message || 'An error occurred. Please try again.');
                    submitBtn.prop('disabled', false);
                    $('.ucbo-btn-text').show();
                    $('.ucbo-btn-loading').hide();
                }
            },
            error: function() {
                alert('An error occurred. Please try again.');
                submitBtn.prop('disabled', false);
                $('.ucbo-btn-text').show();
                $('.ucbo-btn-loading').hide();
            }
        });
    }
    
    function createConfetti($element) {
        const colors = ['#E91E63', '#2196F3', '#FFC107', '#4CAF50', '#9C27B0'];
        const rect = $element[0].getBoundingClientRect();
        
        for (let i = 0; i < 15; i++) {
            const confetti = $('<div class="ucbo-confetti"></div>');
            confetti.css({
                position: 'fixed',
                width: '8px',
                height: '8px',
                backgroundColor: colors[Math.floor(Math.random() * colors.length)],
                borderRadius: '50%',
                left: (rect.left + rect.width / 2) + 'px',
                top: (rect.top + rect.height / 2) + 'px',
                pointerEvents: 'none',
                zIndex: 9999,
                animation: 'confettiPop 1s ease-out forwards'
            });
            
            const angle = (Math.random() * 360) * Math.PI / 180;
            const distance = 50 + Math.random() * 50;
            const tx = Math.cos(angle) * distance;
            const ty = Math.sin(angle) * distance - 100;
            
            confetti.css({
                transform: 'translate(' + tx + 'px, ' + ty + 'px)',
                animationDelay: (i * 0.02) + 's'
            });
            
            $('body').append(confetti);
            
            setTimeout(() => confetti.remove(), 1200);
        }
    }
    
    // Expose confetti function globally for demo page
    window.createConfetti = createConfetti;
    
})(jQuery);

